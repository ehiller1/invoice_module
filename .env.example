# EIME environment variables (Phase 2 — Membrane Transport)

# ---- LLM ----
ANTHROPIC_API_KEY=

# ---- Postgres ----
DATABASE_URL=postgresql://claude:claude_dev@localhost:5432/eime_accounting

# ---- Church & Accounting Configuration ----
# Default church for API operations (can be overridden in request)
DEFAULT_CHURCH_ID=holy_comforter
# Test church ID for integration tests
TEST_CHURCH_ID=test_church
# Current fiscal year (defaults to current year)
FISCAL_YEAR=2026
# Capitalization threshold in USD
CAPITALIZATION_THRESHOLD_USD=2500

# ---- Membrane feature flags ----
EMBARK_MEMBRANE_PHASE_1=1
EMBARK_MEMBRANE_PHASE_2=0
EMBARK_MEMBRANE_PHASE_3=0
EMBARK_MEMBRANE_PHASE_4=0
EMBARK_MEMBRANE_PHASE_5=0
EMBARK_MEMBRANE_PHASE_6=0

# ---- MessageTransport ----
# Options: local | redis | platform
TRANSPORT_BACKEND=local
REDIS_URL=redis://localhost:6379/0
PLATFORM_MESH_URL=

# ---- EventQueryTransport ----
# Options: local | redis | platform
EVENT_QUERY_BACKEND=local
PLATFORM_QUERY_URL=

# ---- CORS & Security ----
# Comma-separated allowed origins (default: http://localhost:* for dev)
# Example: http://localhost:3000,https://books.example.com
ALLOWED_ORIGINS=http://localhost:*
# Trusted reverse proxy secret (optional; if set, X-Proxy-Secret header required for role headers)
TRUSTED_PROXY_SECRET=

# ---- Features ----
# Enable OpenClaw CabinetRuntime and agent runners (default: false to skip in tests)
EIME_ENABLE_CABINET=false
# Run ACS posting in mock mode (default: false = real posting)
EIME_ACS_MOCK=false

# ---- Plaid Integration ----
# Plaid API credentials
PLAID_CLIENT_ID=
PLAID_SECRET=
# Environment: sandbox | development | production
PLAID_ENV=sandbox

# ---- ACS Realm Integration ----
# ACS Realm endpoint URL
ACS_REALM_URL=
# ACS org ID and auth credentials (if using real ACS)
ACS_ORG_ID=
ACS_API_KEY=
